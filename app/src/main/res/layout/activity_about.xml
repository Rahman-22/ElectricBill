<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <ImageView
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:src="@drawable/profile"
            android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Abdul Rahman Nur Hakim Bin Rahim" android:textSize="22sp" android:textStyle="bold"
            android:textColor="@color/black"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Student ID: 2022298054" android:textSize="16sp" android:paddingTop="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="ICT602 — Mobile Technology and Development" android:textSize="16sp"
            android:paddingTop="4dp" android:gravity="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="How to use this app:&#10;1. On the main screen, choose the month.&#10;2. Enter the units used (1–1000 kWh).&#10;3. Slide to set the rebate (0–5%).&#10;4. Tap CALCULATE to see Total Charges and Final Cost.&#10;5. Tap SAVE to store the bill.&#10;6. Tap VIEW HISTORY to see saved bills; tap a bill to view, edit, or delete it."
            android:textSize="15sp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="https://github.com/Rahman-22/Electric-Bill"
            android:autoLink="web"
            android:textSize="16sp"
            android:paddingBottom="20dp"
            android:textColorLink="@color/blue"/>

        <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnBack" android:layout_width="match_parent" android:background="@drawable/bg_gradient"
            android:textColor="@color/white"
            android:layout_height="wrap_content" android:text="BACK" android:layout_marginTop="20dp"/>
    </LinearLayout>
</ScrollView>